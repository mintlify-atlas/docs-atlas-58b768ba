  "keyFeatures": [
    "Full API translation between Anthropic Messages API and OpenAI Chat Completions",
    "OAuth device code authentication with GitHub Copilot",
    "Web search capability via Brave Search API or DuckDuckGo",
    "Docker support with automatic restart on reboot",
    "Streaming and non-streaming response translation",
    "Support for Claude Opus, Sonnet, and Haiku models",
    "Zero external dependencies - pure Node.js",
    "Automatic proxy startup via launch script"
  ],
  "publicApiSurface": [
    "POST /v1/messages - Main messages endpoint (Anthropic format)",
    "GET /health - Health check endpoint",
    "GET /models - List available Claude models",
    "POST /count_tokens - Token counting endpoint",
    "node scripts/auth.mjs - GitHub OAuth authentication",
    "node scripts/proxy.mjs - Start proxy server",
    "bash scripts/launch.sh - Auto-start proxy and Claude Code",
    "docker compose up -d - Run proxy in Docker"
  ]
}
